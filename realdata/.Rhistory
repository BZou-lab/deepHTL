legend.text  = element_text(size = 8),
legend.key.size = unit(6, "pt"),        # key box size
legend.spacing.y = unit(2, "pt")        # vertical spacing between items
) +
guides(fill = guide_legend(
ncol = 1,                     # keep single column; try ncol=2 if you want it shorter
keyheight = unit(6, "pt"),
keywidth  = unit(10, "pt"),
title.position = "top"        # compact title
))
